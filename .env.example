# --- Postgres (используется и контейнером postgres, и приложением) ---
DATABASE_NAME=appdb
DATABASE_USER=root
DATABASE_PASSWORD=changeme_strong_password

# DATABASE_HOST / DATABASE_PORT заданы в docker-compose.yml (postgres:5432) — здесь не нужны

# --- JWT / auth ---
SECRET_KEY=replace_with_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_COOKIE_SECURE=False

# --- App ---
DEBUG=False
PORT=8000

# --- gRPC сервисы (если не используются на демо — оставь как есть) ---
RAG_GRPC_URL=host.docker.internal:50051
SUMMARY_GRPC_URL=host.docker.internal:50052

# --- Внешняя БД статей (заполни реальными значениями) ---
ARTICLES_DATABASE_HOST=
ARTICLES_DATABASE_PORT=5433
ARTICLES_DATABASE_NAME=arxivdb
ARTICLES_DATABASE_USER=
ARTICLES_DATABASE_PASSWORD=
